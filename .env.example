# Argus Environment Variables
# Copy this to .env and fill in values
# NEVER commit .env to git

# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────
ARGUS_DB_PASSWORD=change_me_generate_strong_password

# ─────────────────────────────────────────────────────────────
# Zabbix
# ─────────────────────────────────────────────────────────────
ZABBIX_PASSWORD=zabbix_admin_password

# ─────────────────────────────────────────────────────────────
# ntopng
# ─────────────────────────────────────────────────────────────
NTOPNG_PASSWORD=ntopng_admin_password

# ─────────────────────────────────────────────────────────────
# Keycloak
# ─────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN_PASSWORD=keycloak_admin_password

# ─────────────────────────────────────────────────────────────
# Twilio
# ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_SMS_FROM=+1234567890

# ─────────────────────────────────────────────────────────────
# SMTP (for email alerts)
# ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your_app_password

# ─────────────────────────────────────────────────────────────
# Keygen.sh License
# ─────────────────────────────────────────────────────────────
KEYGEN_ACCOUNT_ID=your_keygen_account_id
KEYGEN_PRODUCT_TOKEN=your_keygen_product_token
LICENSE_KEY=your_license_key_here

# ─────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
NODE_ENV=production
